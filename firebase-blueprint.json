{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "SavedPlan": {
      "title": "SavedPlan",
      "description": "A weekly meal plan and shopping list saved by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "planData": { "type": "string", "description": "JSON stringified WeeklyPlanResponse" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "planData", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "savedPlans/{planId}": {
      "schema": { "$ref": "#/entities/SavedPlan" },
      "description": "Saved meal plans"
    }
  }
}
